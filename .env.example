# Jira / Confluence (same credentials — Atlassian API token)
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_atlassian_api_token_here
JIRA_PROJECT_KEY=YOUR_PROJECT_KEY

# Confluence — find these in your space settings
CONFLUENCE_SPACE_ID=12345
CONFLUENCE_PARENT_PAGE_ID=67890

# Anthropic (required for jira_agent_ui.py conversational mode)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
